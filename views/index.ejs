<!DOCTYPE html>
<html>
<head>
<title>Bulk STK Push</title>
<style>
body{font-family:Arial;max-width:1000px;margin:auto;padding:20px}
textarea{width:100%;height:200px}
input{width:100%;padding:8px;margin:5px 0}
table{width:100%;border-collapse:collapse}
td,th{border:1px solid #ccc;padding:8px}
</style>
</head>
<body>
<h1>SunPay Bulk STK Push</h1>

<form method="POST" action="/send">
<label>Phone Numbers (one per line)</label>
<textarea name="numbers"></textarea>

<label>Amount</label>
<input type="number" name="amount" required>

<label>Reference</label>
<input type="text" name="reference" required>

<button type="submit">Send STK Pushes</button>
</form>

<h2>Logs</h2>
<table>
<tr><th>Time</th><th>Phone</th><th>Status</th><th>Response</th></tr>
<% logs.forEach(log => { %>
<tr>
<td><%= log.time %></td>
<td><%= log.phoneNumber %></td>
<td><%= log.status %></td>
<td><%= log.response %></td>
</tr>
<% }) %>
</table>
</body>
</html>